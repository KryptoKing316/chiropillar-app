# ============================================================
# Kingdom Broker — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it is gitignored.
# ============================================================

# --- Supabase ---
# Found at: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Server-only — NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# --- AI ---
# Server-only — NEVER expose to the client
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Data Enrichment APIs ---
# Server-only
SERPER_API_KEY=your-serper-key-here
APOLLO_API_KEY=your-apollo-key-here

# --- Google Sheets Export ---
# Server-only
GOOGLE_SHEETS_ID=your-google-sheets-id-here
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# --- Upstash Redis (Rate Limiting) ---
# Server-only — get from console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# --- Internal API Security ---
# A strong random secret used to authenticate internal agent trigger calls.
# Generate with: openssl rand -hex 32
# Used in: Authorization: Internal <secret> header on POST /api/run-agents
INTERNAL_API_SECRET=your-internal-secret-here-generate-with-openssl-rand-hex-32

# --- Plaid (bank connection · Transactions + Balances, 24 months) ---
# Dashboard: https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=your-plaid-client-id-here
PLAID_SECRET_SANDBOX=your-sandbox-secret-here
PLAID_SECRET_DEVELOPMENT=your-development-secret-here
PLAID_SECRET_PRODUCTION=your-production-secret-here
PLAID_ENV=sandbox
# Optional — set this once you have a public domain. Plaid POSTs transaction
# sync notifications here. Configure in Plaid dashboard OR override per env.
PLAID_WEBHOOK_URL=

# --- QuickBooks Online (P&L + Balance Sheet + Chart of Accounts, 3 yrs) ---
# Dashboard: https://developer.intuit.com/app/developer/myapps
QBO_CLIENT_ID=your-qbo-client-id-here
QBO_CLIENT_SECRET=your-qbo-client-secret-here
# Must match exactly what's registered in your Intuit app dashboard. In prod:
# https://app.kingdombroker.com/api/qbo/callback
QBO_REDIRECT_URI=http://localhost:3001/api/qbo/callback
QBO_ENV=sandbox

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3001
